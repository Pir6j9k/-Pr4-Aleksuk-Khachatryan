<Page x:Class="Практическая_работа_4_Алексюк_Хачатрян.Pages.SecondPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Практическая_работа_4_Алексюк_Хачатрян.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="SecondPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Image Grid.Row="0" Source="/Images/SecondCaseImg.jpg" Margin="10"/>

        <StackPanel Grid.Row="1" HorizontalAlignment="Left" Margin="10" VerticalAlignment="Top" Orientation="Horizontal">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="top">
                    <TextBlock Text="x" Margin="10" HorizontalAlignment="Right"/>
                    <TextBlock Text="b" Margin="10" HorizontalAlignment="Right"/>
                </StackPanel>

                <StackPanel  Grid.Column="1" VerticalAlignment="Center" >
                    <TextBox x:Name="XTextBox" Margin="10" Width="100" PreviewTextInput="NumberValidationTextBox"/>
                    <TextBox x:Name="BTextBox" Margin="10" Width="100" PreviewTextInput="NumberValidationTextBox"/>
                    <StackPanel Margin="10">
                        <RadioButton x:Name="ShRadio" Content="sh(x)" Margin="0,5,0,5"/>
                        <RadioButton x:Name="SquareRadio" Content="x^2" Margin="0,5,0,5"/>
                        <RadioButton x:Name="ExpRadio" Content="e^x" Margin="0,5,0,5"/>

                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Ответ" Margin="10" />
                    <TextBox x:Name="ResultTextBox" Margin="10" Width="100" IsReadOnly="True"/>
                </StackPanel>

            </Grid>
            
        </StackPanel>

        <StackPanel Grid.Row="2" HorizontalAlignment="Left" Orientation="Horizontal">
            <Button x:Name="CountBtn" Content="Вычислить" Padding="5" Margin="10"/>
            <Button x:Name="CleanBtn" Content="Очистить" Margin="10" Padding="5" />
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button x:Name="BackBtn" Grid.Row="2" Content="Назад" Margin="10" Padding="5" Click="BackBtn_Click" />
            <Button x:Name="ExitBtn" Grid.Row="2" Content="Выйти" Margin="10" Padding="5" Click="ExitBtn_Click" />
        </StackPanel>

    </Grid>

</Page>
